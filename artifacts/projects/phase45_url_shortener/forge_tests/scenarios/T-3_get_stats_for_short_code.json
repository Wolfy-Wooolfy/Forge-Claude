{
  "id": "T-3",
  "name": "get_stats_for_short_code",
  "description": "GET /stats/:code with a known shortCode returns 200 + visit count",
  "category": "http",
  "fixture": "fresh_db",
  "setup": {
    "actions": [
      {
        "type": "start_server",
        "command": "node src/server.js",
        "wait_for_port": 3000,
        "timeout_ms": 5000
      },
      {
        "type": "http_request",
        "method": "POST",
        "url": "http://localhost:3000/shorten",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "url": "http://www.example.com"
        }
      }
    ]
  },
  "execution": {
    "type": "http_request",
    "method": "GET",
    "url": "http://localhost:3000/stats/{{created.shortCode}}",
    "headers": {}
  },
  "assertions": [
    {
      "type": "http_status_equals",
      "expected": 200
    },
    {
      "type": "response_body_contains_key",
      "key": "visitCount"
    }
  ],
  "teardown": {
    "actions": [
      {
        "type": "stop_server"
      }
    ]
  },
  "metadata": {
    "covers_ac": [
      "AC-3"
    ],
    "estimated_duration_ms": 500
  }
}