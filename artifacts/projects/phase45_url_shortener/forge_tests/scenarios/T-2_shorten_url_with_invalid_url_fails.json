{
  "id": "T-2",
  "name": "shorten_url_with_invalid_url_fails",
  "description": "POST /shorten with an invalid URL should return 400 and an error message",
  "category": "http",
  "setup": {
    "actions": [
      {
        "type": "start_server",
        "command": "node src/server.js",
        "wait_for_port": 3000,
        "timeout_ms": 5000
      }
    ]
  },
  "execution": {
    "type": "http_request",
    "method": "POST",
    "url": "http://localhost:3000/shorten",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "url": "invalid-url"
    }
  },
  "assertions": [
    {
      "type": "http_status_equals",
      "expected": 400
    },
    {
      "type": "response_body_contains_key",
      "key": "error"
    }
  ],
  "teardown": {
    "actions": [
      {
        "type": "stop_server"
      }
    ]
  },
  "metadata": {
    "covers_ac": [
      "AC-1",
      "AC-6",
      "AC-8"
    ],
    "estimated_duration_ms": 500
  }
}