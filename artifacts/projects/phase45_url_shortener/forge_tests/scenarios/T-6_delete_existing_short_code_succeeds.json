{
  "id": "T-6",
  "name": "delete_existing_short_code_succeeds",
  "description": "DELETE /:shortCode should delete the short code from memory",
  "category": "http",
  "setup": {
    "actions": [
      {
        "type": "start_server",
        "command": "node src/server.js",
        "wait_for_port": 3000,
        "timeout_ms": 5000
      },
      {
        "type": "http_request",
        "method": "POST",
        "url": "http://localhost:3000/shorten",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "url": "http://example.com"
        }
      }
    ]
  },
  "execution": {
    "type": "http_request",
    "method": "DELETE",
    "url": "http://localhost:3000/{{created.shortCode}}",
    "headers": {}
  },
  "assertions": [
    {
      "type": "http_status_equals",
      "expected": 204
    }
  ],
  "teardown": {
    "actions": [
      {
        "type": "stop_server"
      }
    ]
  },
  "metadata": {
    "covers_ac": [
      "AC-4"
    ],
    "estimated_duration_ms": 500
  }
}