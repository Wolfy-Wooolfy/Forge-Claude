{
  "id": "T-2",
  "name": "create_shorten_link_invalid_url",
  "description": "POST /shorten with an invalid URL returns 400 and an error message",
  "category": "http",
  "fixture": "fresh_db",
  "setup": {
    "actions": [
      {
        "type": "start_server",
        "command": "node src/server.js",
        "wait_for_port": 3000,
        "timeout_ms": 5000
      }
    ]
  },
  "execution": {
    "type": "http_request",
    "method": "POST",
    "url": "http://localhost:3000/shorten",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "url": "invalid-url"
    }
  },
  "assertions": [
    {
      "type": "http_status_equals",
      "expected": 400
    },
    {
      "type": "response_body_field_equals",
      "field": "error.message",
      "expected": "Invalid URL"
    }
  ],
  "teardown": {
    "actions": [
      {
        "type": "stop_server"
      }
    ]
  },
  "metadata": {
    "covers_ac": [
      "AC-1"
    ],
    "estimated_duration_ms": 500
  }
}