  "name": "get_stats_for_existing_short_code",
  "description": "GET /:shortCode/stats returns 'visitCount' of an existing short code.",
  "category": "http",
  "fixture": "fresh_db",
  "setup": {
    "actions": [
      {
        "type": "start_server",
        "command": "node src/server.js",
        "wait_for_port": 3000,
        "timeout_ms": 5000
      },
      {
        "type": "http_request",
        "method": "POST",
        "url": "http://localhost:3000/shorten",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "longUrl": "http://example.net"
        }
      }
    ]
  },
  "execution": {
    "type": "http_request",
    "method": "GET",
    "url": "http://localhost:3000/{{created.shortCode}}/stats",
    "headers": {},
    "body": null
  },
  "assertions": [
    {
      "type": "http_status_equals",
      "expected": 200
