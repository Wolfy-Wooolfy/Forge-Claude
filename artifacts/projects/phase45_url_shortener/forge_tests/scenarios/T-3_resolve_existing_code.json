{
  "id": "T-3",
  "name": "resolve_existing_code",
  "description": "GET /:code for an existing short code redirects to the original URL",
  "category": "http",
  "fixture": "fresh_db",
  "setup": {
    "actions": [
      {
        "type": "start_server",
        "command": "node src/server.js",
        "wait_for_port": 3000,
        "timeout_ms": 5000
      },
      {
        "type": "http_request",
        "method": "POST",
        "url": "http://localhost:3000/shorten",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "url": "http://example.com"
        }
      }
    ]
  },
  "execution": {
    "type": "http_request",
    "method": "GET",
    "url": "http://localhost:3000/{{created.shortCode}}",
    "headers": {}
  },
  "assertions": [
    {
      "type": "http_status_equals",
      "expected": 302
    },
    {
      "type": "response_header_equals",
      "header": "Location",
      "expected": "http://example.com"
    }
  ],
  "teardown": {
    "actions": [
      {
        "type": "stop_server"
      }
    ]
  },
  "metadata": {
    "covers_ac": [
      "AC-2"
    ],
    "estimated_duration_ms": 500
  }
}