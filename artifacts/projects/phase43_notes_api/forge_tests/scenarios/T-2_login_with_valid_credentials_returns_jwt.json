{
  "id": "T-2",
  "name": "login_with_valid_credentials_returns_jwt",
  "description": "POST /auth/login with correct credentials returns a JWT token",
  "category": "http",
  "fixture": "fresh_db",
  "setup": {
    "actions": [
      {
        "type": "start_server",
        "command": "node app.js",
        "wait_for_port": 3000,
        "timeout_ms": 5000
      }
    ]
  },
  "execution": {
    "type": "http_request",
    "method": "POST",
    "url": "http://localhost:3000/auth/login",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "username": "alice",
      "password": "secure123"
    }
  },
  "assertions": [
    {
      "type": "http_status_equals",
      "expected": 200
    },
    {
      "type": "response_body_contains_key",
      "key": "token"
    }
  ],
  "teardown": {
    "actions": [
      {
        "type": "stop_server"
      }
    ]
  },
  "metadata": {
    "covers_ac": [
      "AC-2"
    ],
    "estimated_duration_ms": 500
  }
}