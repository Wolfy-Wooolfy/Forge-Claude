{
  "id": "T-2",
  "name": "get_all_notes",
  "description": "GET /notes retrieves all notes",
  "category": "http",
  "setup": {
    "actions": [
      {
        "type": "start_server",
        "command": "node src/server.js",
        "wait_for_port": 3000,
        "timeout_ms": 5000
      },
      {
        "type": "http_request",
        "method": "POST",
        "url": "http://localhost:3000/notes",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "title": "Test Note",
          "body": "Test Body",
          "category": "test",
          "tags": [
            "test1"
          ]
        }
      }
    ]
  },
  "execution": {
    "type": "http_request",
    "method": "GET",
    "url": "http://localhost:3000/notes",
    "headers": {}
  },
  "assertions": [
    {
      "type": "http_status_equals",
      "expected": 200
    },
    {
      "type": "response_body_is_array",
      "min_length": 1,
      "max_length": 10
    }
  ],
  "teardown": {
    "actions": [
      {
        "type": "stop_server"
      }
    ]
  },
