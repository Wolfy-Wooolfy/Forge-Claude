{
  "id": "T-4",
  "name": "fetch_single_note_by_id",
  "description": "GET /notes/:id returns the note object",
  "category": "http",
  "setup": {
    "actions": [
      {
        "type": "start_server",
        "command": "node src/server.js",
        "wait_for_port": 3000,
        "timeout_ms": 5000
      },
      {
        "type": "http_request",
        "method": "POST",
        "url": "http://localhost:3000/notes",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "title": "Single Note",
          "body": "This is a note to fetch",
          "category": "fetch",
          "tags": [
            "fetch"
          ]
        }
      }
    ]
  },
  "execution": {
    "type": "http_request",
    "method": "GET",
    "url": "http://localhost:3000/notes/1",
    "headers": {
      "Accept": "application/json"
    }
  },
  "assertions": [
    {
      "type": "http_status_equals",
      "expected": 200
    },
    {
      "type": "response_body_field_equals",
      "field": "title",
      "expected": "Single Note"
    }
  ],
  "teardown": {
    "actions": [
      {
        "type": "stop_server"
      }
    ]
  },
  "metadata": {
    "covers_ac": [
      "AC-3"
    ],
    "estimated_duration_ms": 500
  }
}