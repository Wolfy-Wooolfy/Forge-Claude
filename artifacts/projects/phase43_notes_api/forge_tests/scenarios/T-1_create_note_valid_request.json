{
  "id": "T-1",
  "name": "create_note_valid_request",
  "description": "POST /notes with valid payload creates a note and returns 201 with the note's ID",
  "category": "http",
  "setup": {
    "actions": [
      {
        "type": "start_server",
        "command": "node src/server.js",
        "wait_for_port": 3000,
        "timeout_ms": 5000
      }
    ]
  },
  "execution": {
    "type": "http_request",
    "method": "POST",
    "url": "http://localhost:3000/notes",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "title": "My First Note",
      "body": "This is the body of the note",
      "category": "personal",
      "tags": [
        "tag1",
        "tag2"
      ]
    }
  },
  "assertions": [
    {
      "type": "http_status_equals",
      "expected": 201
    },
    {
      "type": "response_body_contains_key",
      "key": "id"
    }
  ],
  "teardown": {
    "actions": [
      {
        "type": "stop_server"
      }
    ]
  },
  "metadata": {
    "covers_ac": [
      "AC-1"
    ],
    "estimated_duration_ms": 500
  }
}