{
  "id": "T-1",
  "name": "create_note_success",
  "description": "POST /notes with valid data returns 201 and the created note",
  "category": "http",
  "setup": {
    "actions": [
      {
        "type": "start_server",
        "command": "node src/server.js",
        "wait_for_port": 3000,
        "timeout_ms": 5000
      }
    ]
  },
  "execution": {
    "type": "http_request",
    "method": "POST",
    "url": "http://localhost:3000/notes",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "title": "Meeting Notes",
      "body": "Plan for the project kick-off meeting",
      "category": "Work",
      "tags": [
        "meeting",
        "project"
      ]
    }
  },
  "assertions": [
    {
      "type": "http_status_equals",
      "expected": 201
    },
    {
      "type": "response_body_contains_key",
      "key": "id"
    },
    {
      "type": "response_body_field_equals",
      "field": "title",
      "expected": "Meeting Notes"
    }
  ],
  "teardown": {
    "actions": [
      {
        "type": "stop_server"
      }
    ]
  },
  "metadata": {
    "covers_ac": [
      "AC-1"
    ],
    "estimated_duration_ms": 500
  }
}