{
  "id": "T-2",
  "name": "list_notes_no_filter",
  "description": "GET /notes without filters returns a list of all notes",
  "category": "http",
  "setup": {
    "actions": [
      {
        "type": "start_server",
        "command": "node src/server.js",
        "wait_for_port": 3000,
        "timeout_ms": 5000
      },
      {
        "type": "http_request",
        "method": "POST",
        "url": "http://localhost:3000/notes",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "title": "First Note",
          "body": "Body of first note",
          "category": "General",
          "tags": [
            "first",
            "general"
          ]
        }
      },
      {
        "type": "http_request",
        "method": "POST",
        "url": "http://localhost:3000/notes",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "title": "Second Note",
          "body": "Body of second note",
          "category": "General",
          "tags": [
            "second",
            "general"
          ]
        }
      }
    ]
  },
  "execution": {
    "type": "http_request",
    "method": "GET",
    "url": "http://localhost:3000/notes",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {}
  },
  "assertions": [
    {
      "type": "http_status_equals",
      "expected": 200
    },
    {
      "type": "response_body_is_array",
      "min_length": 2,
      "max_length": 10
    }
  ],
  "teardown": {
    "actions": [
      {
        "type": "stop_server"
      }
    ]
  },
  "metadata": {
    "covers_ac": [
      "AC-2"
    ],
    "estimated_duration_ms": 600
  }
}