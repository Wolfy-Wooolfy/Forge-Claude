{
  "id": "T-3",
  "name": "retrieve_all_notes_with_filter",
  "description": "GET /notes retrieves list filtered by category",
  "category": "http",
  "setup": {
    "actions": [
      {
        "type": "start_server",
        "command": "node src/server.js",
        "wait_for_port": 3000,
        "timeout_ms": 5000
      },
      {
        "type": "http_request",
        "method": "POST",
        "url": "http://localhost:3000/notes",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "title": "Filtered Note",
          "body": "This is a test note",
          "category": "special",
          "tags": [
            "test"
          ]
        }
      }
    ]
  },
  "execution": {
    "type": "http_request",
    "method": "GET",
    "url": "http://localhost:3000/notes?category=special",
    "headers": {
      "Accept": "application/json"
    }
  },
  "assertions": [
    {
      "type": "http_status_equals",
      "expected": 200
    },
    {
      "type": "response_body_is_array",
      "min_length": 1,
      "max_length": 10
    }
  ],
  "teardown": {
    "actions": [
      {
        "type": "stop_server"
      }
    ]
  },
  "metadata": {
    "covers_ac": [
      "AC-2"
    ],
    "estimated_duration_ms": 500
  }
}