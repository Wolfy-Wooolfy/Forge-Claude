{
  "id": "T-5",
  "name": "update_note_returns_200",
  "description": "PUT /notes/:id updates a note and returns 200 with the updated note",
  "category": "http",
  "fixture": "fresh_db",
  "setup": {
    "actions": [
      {
        "type": "start_server",
        "command": "node src/server.js",
        "wait_for_port": 3000,
        "timeout_ms": 5000
      },
      {
        "type": "http_request",
        "method": "POST",
        "url": "http://localhost:3000/notes",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "title": "Initial Note",
          "body": "Original content",
          "category": "Drafts",
          "tags": [
            "edit",
            "draft"
          ]
        }
      }
    ]
  },
  "execution": {
    "type": "http_request",
    "method": "PUT",
    "url": "http://localhost:3000/notes/{{created.id}}",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "title": "Updated Note",
      "body": "Updated content",
      "category": "Final",
      "tags": [
        "edit",
        "final"
      ]
    }
  },
  "assertions": [
    {
      "type": "http_status_equals",
      "expected": 200
    },
    {
      "type": "response_body_field_equals",
      "field": "title",
      "expected": "Updated Note"
    }
  ],
  "teardown": {
    "actions": [
      {
        "type": "stop_server"
      }
    ]
  },
  "metadata": {
    "covers_ac": [
      "AC-4"
    ],
    "estimated_duration_ms": 500
  }
}