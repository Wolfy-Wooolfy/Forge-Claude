{
  "id": "T-4",
  "name": "update_note_success",
  "description": "PUT /notes/:id to update fields of an existing note returns 200 with updated note",
  "category": "http",
  "setup": {
    "actions": [
      {
        "type": "start_server",
        "command": "node src/server.js",
        "wait_for_port": 3000,
        "timeout_ms": 5000
      },
      {
        "type": "http_request",
        "method": "POST",
        "url": "http://localhost:3000/notes",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "title": "Original Title",
          "body": "Initial body content",
          "category": "Work",
          "tags": [
            "update",
            "test"
          ]
        }
      }
    ]
  },
  "execution": {
    "type": "http_request",
    "method": "PUT",
    "url": "http://localhost:3000/notes/{{created.id}}",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "title": "Updated Title",
      "body": "Updated body content"
    }
  },
  "assertions": [
    {
      "type": "http_status_equals",
      "expected": 200
    },
    {
      "type": "response_body_field_equals",
      "field": "title",
      "expected": "Updated Title"
    }
  ],
  "teardown": {
    "actions": [
      {
        "type": "stop_server"
      }
    ]
  },
  "metadata": {
    "covers_ac": [
      "AC-4"
    ],
    "estimated_duration_ms": 500
  }
}