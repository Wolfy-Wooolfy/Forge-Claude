# ============================================================================
# Forge — .gitignore (v3 FINAL)
# ============================================================================
#
# Goal: full project portability on GitHub.
# Strategy: commit source-of-truth + governance trail; ignore environment-
#           specific, sensitive, and machine-generated content.
#
# Audited 2026-05-13 by CTO advisor after 2 prior failed attempts.
# DO NOT modify without checking artifacts/decisions/ for governance impact.
# ============================================================================


# -- 1. SECRETS — NEVER commit -----------------------------------------------

.env
.env.local
.env.*.local
.env.development
.env.production
*.pem
*.key
*.p12
*.pfx
secrets/
.secrets/
# Source code (provider implementations) must be tracked despite the secrets/ rule above
!code/src/runtime/secrets/
!code/src/runtime/secrets/**

# Owner-specific personal logs
MY_FORGE_PROGRESS.md


# -- 2. MACHINE-SPECIFIC CONFIG -----------------------------------------------
# These contain absolute paths or per-machine settings.
# Khaled's .local.json has "d:\\S\\Halo\\Tech\\Forge-Claude" hardcoded.

.claude/cache/
.vscode/settings.json
.vscode/launch.json
!.vscode/extensions.json

# JetBrains
.idea/workspace.xml
.idea/tasks.xml
.idea/usage.statistics.xml
.idea/shelf/


# -- 3. NODE / NPM / DEPENDENCIES ---------------------------------------------

node_modules/
**/node_modules/
.npm/
.pnpm-store/
.yarn/
.yarn-integrity

# Build outputs
.cache/
.parcel-cache/
.vite/
.next/
.nuxt/
dist/
build/


# -- 4. PYTHON ----------------------------------------------------------------

__pycache__/
*.py[cod]
*$py.class
.Python
.venv/
venv/
/env/
.pytest_cache/


# -- 5. OS / EDITOR CRUFT -----------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# Editors
.idea/
*.swp
*.swo
.cursor/

# PowerShell escaping accidents (PHASE-8 closure note)
resolve(data))
v.severity
${APPDATA}/


# -- 6. RUNTIME LLM TRACES (high-volume, regenerable) ------------------------
# These accumulate every LLM call. Forge regenerates them on use.
# NOT source-of-truth — these are operational telemetry.


# KEEP committed: artifacts/llm/approval_policy.json (governance config)
# KEEP committed: artifacts/llm/decision_log.json (until >1MB)


# -- 7. RUNTIME LOGS (per-call audit JSONL) -----------------------------------
# High-volume JSONL within otherwise-governance folders.
# We ignore ONLY the JSONL files, not the folder.

artifacts/ai/cost_ledger.jsonl
# Step 2 audit findings (2026-05-17) — extend §7 RUNTIME LOGS:
artifacts/agent/activity.jsonl
artifacts/agent/cost_ledger.jsonl
artifacts/audit/permission_audit.jsonl
artifacts/audit/tool_audit.jsonl

# LLM forensic trace — per-call dumps, regenerable, high-volume
artifacts/llm/metadata/
artifacts/llm/requests/
artifacts/llm/responses/
artifacts/llm/outputs/

# PCST intake working dirs — Forge copies source into these during intake.
# Regenerable. Source clones are in artifacts/stress_test/<slug>/source_clone/
artifacts/projects/pcst_*/

# Per-run doctor snapshots

# Scenario test run outputs
artifacts/testing/

# Old reset snapshots
artifacts/archive/

# Internal Forge state cache
artifacts/forge/


# -- 8. AI LAYER GOVERNANCE TRAIL — IS COMMITTED -----------------------------
# These are governance records of AI Layer operations (proposals, drafts,
# analysis, conversations, decision_links, context). NOT pre-v2 cruft.
# Generated during PHASE-7-E and PHASE-7-F-X — part of the forensic record.
#
# artifacts/ai/proposals/      — TRACKED — AI proposal records
# artifacts/ai/drafts/         — TRACKED — AI draft outputs
# artifacts/ai/analysis/       — TRACKED — AI analysis mode findings
# artifacts/ai/conversations/  — TRACKED — AI session messages
# artifacts/ai/decision_links/ — TRACKED — proposal→decision_packet links
# artifacts/ai/context/        — TRACKED — AI session context (forensic)
#
# ONLY exception: artifacts/ai/cost_ledger.jsonl is still ignored in §7.


# -- 9. DEBUG / SCRATCH PROJECTS ----------------------------------------------
# Not real demos; leftovers from earlier debugging.
# The reference TODO API at artifacts/projects/_reference_todo_api/ IS kept.

artifacts/projects/test_pip_debug/
artifacts/projects/test_pip_debug2/
artifacts/projects/test_pkg_s48_debug/
artifacts/projects/test_pkg_s57_debug/
artifacts/projects/live_smoke/
artifacts/projects/live_smoke_retry/
artifacts/projects/hr/
artifacts/projects/default_project/
artifacts/projects/active_project.json


# -- 10. PER-PROJECT (built by Forge) — node_modules and binary indexes ------
# For ANY project Forge builds, its node_modules and LanceDB binary indexes
# are regenerable. Source code, vision, tests ARE committed.

artifacts/projects/*/node_modules/
artifacts/projects/*/package-lock.json
artifacts/projects/*/kb/chunks/
artifacts/projects/*/kb/cost_ledger.jsonl
artifacts/_global_kb/chunks/


# -- 11. ATOMIC-WRITE LEFTOVERS -----------------------------------------------

*.tmp
*.jsonl.tmp


# -- 12. LOGS -----------------------------------------------------------------

logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*


# -- 13. COVERAGE / TEST OUTPUTS ----------------------------------------------

/coverage/
.nyc_output/
*.lcov


# -- 14. ARCHIVES & DOWNLOADS -------------------------------------------------

*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z


