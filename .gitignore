/test-docs.json
/test-handoff.json
/test-options.json
/test-output-json-only.json


# ============================================================================
# WHAT IS COMMITTED (source of truth — full inventory)
# ============================================================================
#
# CODE & DOCS:
#   code/**                      — Forge source code
#   docs/**                      — authoritative documentation
#   bin/**                       — CLI entrypoints
#   architecture/**              — Blueprints + Phase Roadmap
#   web/**                       — UI source
#   tests/**                     — Test files
#   tools/**                     — Tooling scripts
#   verify/**                    — Verification scripts
#
# GOVERNANCE TRAIL (Layer-0/1 evidence):
#   progress/status.json         — single source of phase truth
#   artifacts/decisions/**       — all DECISION-*.md (the project's spine)
#   artifacts/stage_A/**         — Stage A closure
#   artifacts/stage_B/**         — Stage B closure
#   artifacts/stage_C/**         — Stage C closure
#   artifacts/stage_D/**         — Stage D closure
#   artifacts/audit/**           — Audit reports (EXCEPT *.jsonl per §7)
#   artifacts/release/**         — Release manifests
#   artifacts/intake/**          — Project intake reports
#   artifacts/orchestration/**   — Orchestration run reports
#   artifacts/verify/**          — Verification reports
#   artifacts/closure/**         — Closure reports
#   artifacts/coverage/**        — Vision coverage matrices
#   artifacts/reports/**         — Autonomy/audit reports
#   artifacts/exploration/**     — Option matrices
#   artifacts/admission/**       — Project admission docs
#   artifacts/gap/**             — Gap reports (Stage B)
#   artifacts/backfill/**        — Backfill execution logs (Stage B)
#   artifacts/execute/**         — Execute diffs and logs (Stage C)
#   artifacts/tasks/**           — TASK-*.closure.md (per-task records)
#   artifacts/env/**             — system_fingerprint.json (evidence)
#   artifacts/cognitive/**       — Agent response trace (full provenance)
#   artifacts/agent/             — Agent runtime config (but NOT *.jsonl)
#
# REFERENCE DEMO PROJECT:
#   artifacts/projects/_reference_todo_api/   — source files only
#     |-- README.md, vision.md
#     |-- server.js, db.js
#     |-- package.json (LOCK ignored per §10)
#     |-- routes/**
#     `-- forge_tests/**         — L5b scenario fixtures
#
# CONFIG & MANIFEST:
#   package.json                 — Forge dependency manifest
#   package-lock.json            — root version lock
#   .gitignore                   — this file
#   .gitattributes               — line ending policy
#   .claude/settings.json        — Claude Code permissions (NO secrets, OK to commit)
#
# ENTRY POINTS:
#   start-api.js                 — Node entry script
#   start.bat                    — Windows launcher
#   cleanup.bat                  — Windows cleanup utility
#   release_*.hashes.json        — Release integrity hashes (root level)
#
# DOCUMENTATION:
#   README.md                    — Repository entry doc
#   CLAUDE.md                    — Claude Code instructions
#   INSTRUCTIONS.md              — Forge orchestration instructions
#
# ============================================================================
 
# -- 16. PCST INTAKE WORKING DIRS (regenerable) ------------------------------
# PCST script's project.intake_zip copies source code into these dirs.
# Regenerable; not part of test deliverables.
# Real test artifacts live in artifacts/stress_test/<slug>/
artifacts/projects/pcst_*/


# -- 17. RUNTIME ARTIFACTS (machine-generated, regenerable) ------------------
# Doctor snapshots, self-test outputs, env fingerprints, orchestration logs,
# built-project runtime state, uid pin, and session files.

artifacts/health/
artifacts/self-test/
artifacts/env/
artifacts/projects/*/orchestration/
artifacts/projects/*/forge_tests/last_report.json
artifacts/projects/*/forge_tests/loopback_signal.json
artifacts/projects/*/intake_state.json
artifacts/projects/project_registry.json
artifacts/projects/*/kb/exports/
artifacts/stage_*/evidence/
progress/uid_pin.json
web/.forge-session
.pm2/
