# ============================================================================
# Forge .gitignore
# ============================================================================
# Strategy: commit source-of-truth, ignore generated/regenerable/sensitive.
# Sections ordered by importance.
# ============================================================================


# -- 1. SECRETS (NEVER commit) -----------------------------------------------
# Anything that could leak credentials, keys, or owner-specific config.

.env
.env.local
.env.*.local
.env.development
.env.production
*.pem
*.key
secrets/
.secrets/
notify-telegram.js

# Owner-specific personal logs not meant for repo
MY_FORGE_PROGRESS.md


# -- 2. NODE / NPM / DEPENDENCIES (regenerable via npm install) ---------------
# node_modules is rebuilt by npm; never commit it.
# package-lock.json IS committed (it locks versions -- that's the point).

node_modules/
**/node_modules/
.npm/
.pnpm-store/
.yarn/

# Caches from build tools
.cache/
.parcel-cache/
.vite/
.next/
.nuxt/
dist/
build/


# -- 3. PYTHON (if Forge ever shells out to Python tooling) -------------------

__pycache__/
*.py[cod]
*$py.class
.Python
.venv/
venv/
env/
.pytest_cache/


# -- 4. OS / EDITOR CRUFT -----------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory

# Editors
.vscode/
!.vscode/settings.json.example
.idea/
*.swp
*.swo
.cursor/

# PowerShell escaping accidents (pre-existing, kept for safety)
resolve(data))
v.severity
${APPDATA}/


# -- 5. RUNTIME ARTIFACTS (regenerable; bloat the repo) -----------------------
# These are written during normal Forge operation. Owner re-runs Forge -- they
# come back. They are NOT source of truth for the codebase.

# LLM trace files -- accumulate fast, can be enormous
artifacts/llm/metadata/
artifacts/llm/requests/
artifacts/llm/responses/
artifacts/llm/input/
artifacts/llm/outputs/
artifacts/llm/use_cases/
# KEEP committed: artifacts/llm/approval_policy.json (governance config)
# KEEP committed: artifacts/llm/decision_log.json (until it grows past 1MB)

# Audit trace logs -- generated per-tool-call
artifacts/audit/
artifacts/trace/

# Per-run health snapshots
artifacts/health/

# Cost ledgers (regenerable; can contain spending detail)
artifacts/ai/cost_ledger.jsonl
artifacts/agent/cost_ledger.jsonl
artifacts/agent/activity.jsonl

# Scenario test runs (regenerable)
artifacts/testing/

# Archives, backups, scratch
artifacts/archive/
artifacts/forge/

# Pipeline stage intermediate outputs (regenerable from inputs)
artifacts/cognitive/
artifacts/intake/
artifacts/exploration/
artifacts/gap/
artifacts/backfill/
artifacts/execute/
artifacts/verify/
artifacts/closure/
artifacts/admission/
artifacts/orchestration/
artifacts/coverage/
artifacts/release/
artifacts/reports/
artifacts/tasks/
artifacts/env/
artifacts/stage_A/
artifacts/stage_B/
artifacts/stage_C/
artifacts/stage_D/


# -- 6. TRANSIENT TEST/DEBUG PROJECTS -----------------------------------------
# Throwaway scratch projects from debugging. Not real demos.

artifacts/projects/test_pip_debug/
artifacts/projects/test_pip_debug2/
artifacts/projects/test_pkg_s48_debug/
artifacts/projects/test_pkg_s57_debug/
artifacts/projects/live_smoke/
artifacts/projects/live_smoke_retry/
artifacts/projects/hr/
artifacts/projects/default_project/
artifacts/projects/active_project.json


# -- 7. PER-PROJECT GENERATED CONTENT -----------------------------------------
# For any project Forge builds, its node_modules and KB indexes are
# regenerable. Source code and vision ARE committed.

artifacts/projects/*/node_modules/
artifacts/projects/*/package-lock.json
artifacts/projects/*/kb/chunks/
artifacts/projects/*/kb/cost_ledger.jsonl

# Global library binary indexes also regenerable
artifacts/_global_kb/chunks/


# -- 8. ATOMIC-WRITE LEFTOVERS ------------------------------------------------
# Should never exist long enough to commit, but belt-and-suspenders.

*.tmp
*.jsonl.tmp


# -- 9. LOGS ------------------------------------------------------------------

logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*


# -- 10. COVERAGE / TEST OUTPUTS (regenerable) --------------------------------

coverage/
.nyc_output/
*.lcov


# -- 11. ARCHIVES & DOWNLOADS (often accidental) ------------------------------

*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z
# Exception: if a fixture explicitly needs to ship as zip, force-add it
# manually with `git add -f path/to/fixture.zip`


# -- 12. RUNTIME AI ARTIFACTS (missed in initial .gitignore) ------------------
# Runtime-generated by Forge during normal operation -- old runs
# accumulated 307+ files. Not source of truth; regenerable.

artifacts/ai/proposals/
artifacts/ai/drafts/
artifacts/ai/conversations/
artifacts/ai/analysis/
artifacts/ai/decision_links/
artifacts/ai/context/


# -- 13. ARCHIVE / RESET SNAPSHOTS --------------------------------------------
# Old project reset snapshots. Not needed for current work.

artifacts/archive/


# -- 14. RELEASE MANIFESTS ----------------------------------------------------
# Version is in package.json + git tags. Regenerable via Forge tooling.
# To keep: comment out the next line.

artifacts/release/


# -- 15. STAGE TRACKING ARTIFACTS (if not already covered) --------------------

artifacts/coverage/


# ============================================================================
# What IS committed (source of truth -- do NOT add to this file):
# ============================================================================
# code/**                      -- Forge source code
# docs/**                      -- authoritative documentation
# bin/**                       -- CLI entrypoints
# architecture/**              -- blueprints + phase roadmap
# artifacts/decisions/**       -- all DECISION-*.md files
# artifacts/projects/_reference_todo_api/   -- reference demo project (source only)
#   |-- README.md, server.js, db.js, vision.md
#   |-- package.json (LOCK file ignored per section 7)
#   |-- routes/**
#   `-- forge_tests/**         -- L5b scenario fixtures
# artifacts/llm/approval_policy.json    -- governance config
# artifacts/llm/decision_log.json       -- until it grows past 1MB
# progress/status.json         -- the single source of phase truth
# package.json + package-lock.json (repo-level)
# README.md, CLAUDE.md, INSTRUCTIONS.md
# .gitignore (this file)
# .gitattributes (if added)
# ============================================================================
