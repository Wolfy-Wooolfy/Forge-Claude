{
  "id": "S17",
  "name": "documentationBuildLoop persists loop state + review log + report via L2",
  "type": "direct_engine",
  "permission": "WORKSPACE_WRITE",
  "engine": "documentationBuildLoop",
  "method": "runDocBuildLoop",
