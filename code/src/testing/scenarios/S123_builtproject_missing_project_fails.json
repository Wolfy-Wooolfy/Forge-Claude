{
  "id": "S123",
  "name": "builtproject.run_scenarios with non-existent project_root returns FAILED",
  "type": "direct_tool",
  "permission": "TEST",
  "tool": "builtproject.run_scenarios",
  "input": {
    "project_root": "artifacts/projects/_does_not_exist_xyz"
  },
  "assertions": [
    { "type": "status_equals",      "expected": "FAILED" },
    { "type": "state_field_equals", "field": "reason", "expected": "PROJECT_NOT_FOUND" }
  ]
}
