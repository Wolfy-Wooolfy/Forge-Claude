{
  "id": "S38",
  "name": "shell.run_with_prompt denies sudo via HARD_DENY_ARGV0",
  "type": "direct_tool",
  "permission": "TEST",
  "tool": "shell.run_with_prompt",
  "input": {
    "argv": ["sudo", "id"]
