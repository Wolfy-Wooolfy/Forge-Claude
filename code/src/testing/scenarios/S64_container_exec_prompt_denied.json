{
  "id": "S64",
  "name": "container.exec in PROMPT mode is DENIED (auto-deny prompter, no interactive session)",
  "type": "direct_tool",
  "permission": "PROMPT",
  "tool": "container.exec",
  "input": {
    "container": "any-container-s64",
    "command": ["sh"],
    "project_id": "test_container_s64"
