{
  "id": "S61",
  "name": "container.run with bind-mount /etc:/etc is HARD_DENY (workspace boundary violation)",
  "type": "direct_tool",
  "permission": "WORKSPACE_WRITE",
  "tool": "container.run",
  "input": {
    "image": "alpine:latest",
    "name": "forge-test-s61",
    "volumes": [{ "host": "/etc", "container": "/etc" }],
    "project_id": "test_container_s61"
  },
  "assertions": [
    { "type": "status_equals",      "expected": "FAILED" },
    { "type": "state_field_equals", "field": "reason",       "expected": "HARD_DENY" },
    { "type": "state_field_equals", "field": "context.rule", "expected": "WORKSPACE_BOUNDARY_VIOLATION" },
    { "type": "state_field_exists", "field": "detail" },
    { "type": "audit_count",        "min": 1 }
  ]
}
