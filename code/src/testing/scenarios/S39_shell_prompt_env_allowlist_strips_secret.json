{
  "id": "S39",
  "name": "shell.run_with_prompt env allowlist strips OPENAI_* from subprocess",
  "type": "direct_tool",
  "permission": "TEST",
  "tool": "shell.run_with_prompt",
  "input": {
    "argv": ["node", "-e", "process.stdout.write(process.env.OPENAI_TEST_S39 || 'STRIPPED')"],
    "env": { "OPENAI_TEST_S39": "secret_value_123" }
  },
  "assertions": [
    { "type": "status_equals",      "expected": "SUCCESS" },
    { "type": "state_field_equals", "field": "stdout",    "expected": "STRIPPED" },
    { "type": "state_field_equals", "field": "exit_code", "expected": 0 },
    { "type": "audit_count",        "min": 1 }
  ]
}
