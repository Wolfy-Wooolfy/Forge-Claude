{
  "id": "S42",
  "name": "env.detect_all returns full fingerprint with required shape",
  "type": "direct_tool",
  "permission": "READ_ONLY",
  "tool": "env.detect_all",
  "input": {
    "use_cache": false
  },
  "assertions": [
    { "type": "status_equals",      "expected": "SUCCESS" },
    { "type": "state_field_equals", "field": "cache_used",          "expected": false },
    { "type": "state_field_exists", "field": "fingerprint.os" },
    { "type": "state_field_exists", "field": "fingerprint.node" },
    { "type": "state_field_exists", "field": "fingerprint.container" },
    { "type": "audit_count",        "min": 1 }
  ]
}
