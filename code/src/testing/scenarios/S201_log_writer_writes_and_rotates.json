{
  "id": "S201",
  "name": "logging — log_writer routes info/warn/error and triggers rotation",
  "type": "module_call",
  "permission": "READ_ONLY",
  "module": "code/src/testing/helpers/monitoring_test_helper",
  "method": "runS201LogWriterRotation",
  "args": [],
  "assertions": [
    { "type": "status_equals",      "expected": "SUCCESS" },
    { "type": "state_field_equals", "field": "info_in_main",          "expected": true },
    { "type": "state_field_equals", "field": "warn_in_both_logs",     "expected": true },
    { "type": "state_field_equals", "field": "error_in_both_logs",    "expected": true },
    { "type": "state_field_equals", "field": "info_NOT_in_error",     "expected": true },
    { "type": "state_field_equals", "field": "rotation_triggered",    "expected": true }
  ]
}
