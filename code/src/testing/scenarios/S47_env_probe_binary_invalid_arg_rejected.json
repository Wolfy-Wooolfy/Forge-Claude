{
  "id": "S47",
  "name": "env.probe_binary with disallowed arg returns FAILED/INVALID_PROBE_ARG",
  "type": "direct_tool",
  "permission": "READ_ONLY",
  "tool": "env.probe_binary",
  "input": {
    "binary": "node",
    "args": ["install"]
  },
  "assertions": [
    { "type": "status_equals",      "expected": "FAILED" },
    { "type": "state_field_equals", "field": "reason", "expected": "INVALID_PROBE_ARG" },
    { "type": "state_field_exists", "field": "detail" },
    { "type": "audit_count",        "min": 1 }
  ]
}
